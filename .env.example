# ═══════════════════════════════════════════════════════
#  OncoAI — Production Environment Variables
# ═══════════════════════════════════════════════════════

# Database
DATABASE_URL=postgresql://oncoai:your_secure_password@db:5432/oncoai

# Security — CHANGE THESE IN PRODUCTION
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
ALLOWED_HOSTS=*

# OpenAI (optional — enables GPT-4o powered summaries)
OPENAI_API_KEY=sk-your-openai-key-here

# Server
PORT=8000
WORKERS=4
DEBUG=false

# SSL (set to true when using HTTPS)
USE_SSL=false
SSL_CERTFILE=/etc/ssl/certs/oncoai.crt
SSL_KEYFILE=/etc/ssl/private/oncoai.key
